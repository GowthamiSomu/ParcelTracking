# ============================================================
#  .env.example  –  Copy this file to .env and fill in real values.
#  .env is gitignored and MUST NOT be committed.
# ============================================================

# SQL Server SA password — used by sqlserver, sqledge, and all connection strings
SA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Connection strings consumed by docker-compose ────────────
SQLSERVER_CONNECTION=Server=sqlserver,1433;Database=ParcelTracking;User Id=sa;Password=REPLACE_WITH_STRONG_PASSWORD;TrustServerCertificate=True;
REDIS_CONNECTION=redis:6379
SERVICEBUS_CONNECTION=Endpoint=sb://servicebus-emulator;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
